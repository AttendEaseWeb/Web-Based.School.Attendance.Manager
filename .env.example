# ─────────────────────────────────────────────
# MarkIT Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Port the dev/preview server listens on (optional — defaults to 5173)
PORT=5173

# The n8n webhook URL for the pricing page payment-email form
# Replace with your own n8n instance URL if self-hosting
VITE_N8N_WEBHOOK_URL=https://n8n.getmarkit.app/webhook/payment-email
