# ─────────────────────────────────────────────────────────────
# MarkIT Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server port (Express listens here in dev)
PORT=3001

# Frontend dev server port
VITE_PORT=5173

# PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname
# Render provides this automatically via render.yaml
DATABASE_URL=postgresql://postgres:password@localhost:5432/markit

# JWT signing secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# n8n webhook for the pricing page contact form (optional)
VITE_N8N_WEBHOOK_URL=https://n8n.getmarkit.app/webhook/payment-email
